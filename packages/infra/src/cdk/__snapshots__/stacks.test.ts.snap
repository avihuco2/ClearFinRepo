{
  "cloudTrailConfig": {
    "alertRules": [
      {
        "description": "Alert on IAM policy modifications",
        "eventPattern": {
          "detail": {
            "eventName": [
              "PutRolePolicy",
              "AttachRolePolicy",
              "DetachRolePolicy",
              "DeleteRolePolicy",
              "UpdateAssumeRolePolicy",
            ],
            "eventSource": [
              "iam.amazonaws.com",
            ],
          },
          "detailType": [
            "AWS API Call via CloudTrail",
          ],
          "source": [
            "aws.iam",
          ],
        },
        "name": "clearfin-prod-iam-policy-change",
        "targetSnsTopicName": "clearfin-prod-security-alerts",
      },
      {
        "description": "Alert on STS trust relationship modifications",
        "eventPattern": {
          "detail": {
            "eventSource": [
              "sts.amazonaws.com",
            ],
          },
          "detailType": [
            "AWS API Call via CloudTrail",
          ],
          "source": [
            "aws.sts",
          ],
        },
        "name": "clearfin-prod-sts-trust-change",
        "targetSnsTopicName": "clearfin-prod-security-alerts",
      },
      {
        "description": "Alert on Secrets Manager resource policy modifications",
        "eventPattern": {
          "detail": {
            "eventName": [
              "PutResourcePolicy",
              "DeleteResourcePolicy",
            ],
            "eventSource": [
              "secretsmanager.amazonaws.com",
            ],
          },
          "detailType": [
            "AWS API Call via CloudTrail",
          ],
          "source": [
            "aws.secretsmanager",
          ],
        },
        "name": "clearfin-prod-secrets-policy-change",
        "targetSnsTopicName": "clearfin-prod-security-alerts",
      },
    ],
    "enableLogFileValidation": true,
    "eventSelectors": [
      {
        "dataResources": [
          {
            "type": "AWS::SecretsManager::Secret",
            "values": [
              "arn:aws:secretsmanager:il-central-1:123456789012:secret:/clearfin/prod/*",
            ],
          },
        ],
        "includeManagementEvents": true,
        "readWriteType": "All",
      },
    ],
    "insightSelectors": [
      {
        "insightType": "ApiCallRateInsight",
      },
      {
        "insightType": "ApiErrorRateInsight",
      },
    ],
    "isMultiRegion": false,
    "kmsKeyAlias": "clearfin-prod-secrets-key",
    "monitoredApiCalls": [
      "iam:PutRolePolicy",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:UpdateAssumeRolePolicy",
      "sts:AssumeRole",
      "secretsmanager:PutResourcePolicy",
      "secretsmanager:DeleteResourcePolicy",
      "secretsmanager:CreateSecret",
      "secretsmanager:DeleteSecret",
      "secretsmanager:UpdateSecret",
    ],
    "name": "clearfin-prod-audit-trail",
    "s3BucketName": "clearfin-prod-cloudtrail-logs",
