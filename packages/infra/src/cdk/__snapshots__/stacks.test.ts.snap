          "ttlSeconds": 300,
        },
      ],
      "httpVersion": "http2and3",
      "name": "clearfin-prod-login-distribution",
      "originAccessControl": {
        "name": "clearfin-prod-login-oac",
        "originType": "s3",
        "signingBehavior": "always",
        "signingProtocol": "sigv4",
      },
      "priceClass": "PriceClass_100",
      "responseHeadersPolicy": {
        "name": "clearfin-prod-login-headers",
        "securityHeaders": {
          "contentSecurityPolicy": "default-src 'self'; script-src 'https://clearfin.example.com'; style-src 'https://clearfin.example.com' 'unsafe-inline'; img-src 'https://clearfin.example.com' data:; connect-src 'https://clearfin.example.com'; frame-ancestors 'none'",
          "contentTypeOptions": true,
          "frameOptions": "DENY",
          "referrerPolicy": "strict-origin-when-cross-origin",
          "strictTransportSecurity": "max-age=31536000; includeSubDomains",
          "xssProtection": true,
        },
      },
      "s3Origin": {
        "bucketName": "clearfin-prod-login-page",
      },
      "tags": {
        "Component": "cdn",
        "Environment": "prod",
        "Project": "ClearFin",
      },
      "viewerProtocolPolicy": "redirect-to-https",
    },
    "s3Bucket": {
      "blockPublicAccess": {
        "blockPublicAcls": true,
        "blockPublicPolicy": true,
        "ignorePublicAcls": true,
        "restrictPublicBuckets": true,
      },
      "encryption": {
        "type": "AES256",
      },
      "name": "clearfin-prod-login-page",
      "tags": {
        "Component": "login-page",
        "Environment": "prod",
        "Project": "ClearFin",
      },
      "versioning": true,
    },
  },
  "stackName": "clearfin-prod-static-hosting",
  "tags": {
    "Component": "static-hosting",
    "Environment": "prod",
    "Project": "ClearFin",
  },
}
`;
